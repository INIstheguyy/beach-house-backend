{
  "kind": "collectionType",
  "collectionName": "blocked_dates",
  "info": {
    "singularName": "blocked-date",
    "pluralName": "blocked-dates",
    "displayName": "BlockedDate "
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "property": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::property.property",
      "inversedBy": "blocked_dates"
    },
    "startDate": {
      "type": "date",
      "required": true
    },
    "endDate": {
      "type": "date",
      "required": true
    },
    "reason": {
      "type": "enumeration",
      "enum": [
        "booked",
        "external-booking",
        "maintenance",
        "owner-use",
        "manual-block"
      ]
    },
    "externalId": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "booking": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::booking.booking",
      "inversedBy": "blocked_date"
    },
    "notes": {
      "type": "text"
    }
  }
}
