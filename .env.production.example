# ============================================
# Beach Rentals Backend — Production Environment
# ============================================
# Copy this file and set your actual values in Railway/Render dashboard.
# DO NOT commit real secrets to Git!

# Server
HOST=0.0.0.0
PORT=1337
NODE_ENV=production

# Secrets (GENERATE NEW ONES for production!)
# Run: openssl rand -base64 16 (for each key)
APP_KEYS=<key1>,<key2>,<key3>,<key4>
API_TOKEN_SALT=<generate-random-base64>
ADMIN_JWT_SECRET=<generate-random-base64>
TRANSFER_TOKEN_SALT=<generate-random-base64>
ENCRYPTION_KEY=<generate-random-base64>
JWT_SECRET=<generate-random-base64>

# Database — PostgreSQL (Railway provides DATABASE_URL automatically)
DATABASE_CLIENT=postgres
DATABASE_URL=postgresql://user:password@host:port/dbname
DATABASE_SSL=true

# Frontend URL — Used for CORS and Flutterwave payment redirect
# Set this to your Netlify domain AFTER deploying the frontend
FRONTEND_URL=https://your-app.netlify.app

# Flutterwave — Switch to LIVE keys for production!
# Test keys start with FLWPUBK_TEST- / FLWSECK_TEST-
# Live keys start with FLWPUBK- / FLWSECK-
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-xxxxxxx-X
FLUTTERWAVE_SECRET_KEY=FLWSECK-xxxxxxx-X
FLUTTERWAVE_ENCRYPTION_KEY=<your-encryption-key>
